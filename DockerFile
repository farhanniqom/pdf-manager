# Stage 1: Frontend Build (Tailwind CSS)
FROM node:20-slim AS frontend-builder
WORKDIR /app/frontend
COPY frontend/package*.json ./
RUN npm install
COPY frontend/ ./
# Generate the final output.css
RUN npx tailwindcss -i ./input.css -o ./static/css/output.css

# Stage 2: Python Builder
FROM python:3.11-slim AS python-builder
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libqpdf-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Stage 3: Final Runtime
FROM python:3.11-slim
WORKDIR /app

# Install runtime system dependencies
# libqpdf29: required by pikepdf (Debian Bookworm)
# libgl1, libglib2.0-0: required by pdf2docx/OpenCV
RUN apt-get update && apt-get install -y --no-install-recommends \
    libqpdf29 \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy virtualenv from builder
COPY --from=python-builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy application files
COPY . .

# Overwrite the static CSS with the freshly built one
COPY --from=frontend-builder /app/frontend/static/css/output.css ./frontend/static/css/output.css

# Create storage directories and set permissions
RUN mkdir -p storage/uploads storage/outputs && \
    chmod -R 777 storage

EXPOSE 8000

# Run the application
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
